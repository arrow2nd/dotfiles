{
  "permissions": {
    "allow": [
      "mcp__vv-mcp__say",
      "mcp__pencil"
    ],
    "deny": []
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send-cross \"✹ Claude Code\" \"ユーザーの介入を求めています\""
          },
          {
            "type": "command",
            "command": "notification-sound"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command"
  }
}
